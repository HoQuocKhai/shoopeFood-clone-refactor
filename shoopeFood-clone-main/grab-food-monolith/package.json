    "joi": "^18.2.1",
    "mysql2": "^3.15.2",
    "sequelize": "^6.37.8",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3"
  }
