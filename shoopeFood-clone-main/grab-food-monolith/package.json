{
  "name": "grab-food-monolith",
  "version": "1.0.0",
  "description": "GrabFood monolith backend with Express, Sequelize, EJS and Socket.io",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "jest",
    "test:watch": "jest --watch",
